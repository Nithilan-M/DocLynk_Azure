# Azure MySQL Flexible Server (recommended: use DATABASE_URL)
# Format:
# mysql+pymysql://<user>:<password>@<server>.mysql.database.azure.com:3306/<db>?ssl_mode=require
DATABASE_URL=mysql+pymysql://doclynk_admin:<url-encoded-password>@your-server.mysql.database.azure.com:3306/doclynk?ssl_mode=require

# Fallback DB_* variables if DATABASE_URL is not set
DB_HOST=your-server.mysql.database.azure.com
DB_NAME=doclynk
DB_USER=doclynk_admin
DB_PASSWORD=<strong-password>
DB_PORT=3306
DB_SSL_MODE=require
DB_SSL_CA=

# Auth and OTP
JWT_SECRET_KEY=replace-with-64-char-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_SECRET_KEY=replace-with-64-char-random-secret

# CORS and public URLs
FRONTEND_ORIGINS=https://your-static-app.azurestaticapps.net,https://your-custom-domain.com
FRONTEND_PUBLIC_URL=https://your-static-app.azurestaticapps.net
BACKEND_PUBLIC_URL=https://your-backend-container-app.azurecontainerapps.io

# Email provider
RESEND_API_KEY=
RESEND_FROM_EMAIL=DocLynk <onboarding@resend.dev>